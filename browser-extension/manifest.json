{
    "manifest_version":  3,
    "name":  "Company DLP Browser Protection",
    "version":  "3.0.4",
    "description":  "Blocks browser-wide file picker, drag/drop, paste and real File upload paths; transport enforcement is silent; the tiled watermark is rendered only by the Windows desktop overlay to prevent iframe duplication.",
    "key":  "",
    "permissions":  [
                        "storage",
                        "nativeMessaging",
                        "downloads",
                        "tabs"
                    ],
    "host_permissions":  [
                             "<all_urls>"
                         ],
    "background":  {
                       "service_worker":  "service-worker.js"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "<all_urls>"
                                            ],
                                "js":  [
                                           "page-guard.js"
                                       ],
                                "run_at":  "document_start",
                                "all_frames":  true,
                                "match_about_blank":  true,
                                "match_origin_as_fallback":  true,
                                "world":  "MAIN"
                            },
                            {
                                "matches":  [
                                                "<all_urls>"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_start",
                                "all_frames":  true,
                                "match_about_blank":  true,
                                "match_origin_as_fallback":  true
                            }
                        ],
    "action":  {
                   "default_title":  "Company DLP is managed by your organization"
               },
    "storage":  {
                    "managed_schema":  "managed-storage-schema.json"
                }
}
